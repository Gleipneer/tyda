# Reflektionsarkiv – backend miljövariabler
# Kopiera till .env:  copy .env.example .env  (Windows)  eller  cp .env.example .env  (Mac/Linux)
# Fyll i dina värden nedan.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=reflektionsarkiv
#
# MySQL-konto för backend (DB_USER / DB_PASSWORD) — rättigheter sätts i database/scripts/grants.sql (GRANT/REVOKE).
#
# • Lokal utveckling: root (eller annat konto som får importera schema) under första setup.
# • Efter: mysql -u root -p < database/scripts/grants.sql  — byt sedan till least-privilege:
#   DB_USER=reflektionsarkiv_app
#   DB_PASSWORD=app_password_placeholder
# Verifiera anslutning: GET /api/db-health (fältet mysql_connection_as).
#
# Schema/migrationer: kör som root eller reflektionsarkiv_admin — inte app-kontot (docs/DATABASE_SAKERHET.md).
DB_USER=root
DB_PASSWORD=

# Valfritt: AI-tolkning (server-side, nyckel exponeras aldrig i frontend)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# CORS: komma-separerade frontend-URL:er i produktion (utöver lokala Vite-portar), t.ex. https://min-app.pages.dev
CORS_ORIGINS=

# JWT för inloggning (byt till en lång slumpmässig hemlighet i produktion)
JWT_SECRET=dev-tyda-bytes-i-produktion-minst-32-tecken
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Sällan: felsökning av begreppsmatchning (POST /api/analyze/match-trace)
TYDA_MATCH_DEBUG=false
