# Reflektionsarkiv – backend miljövariabler
# Kopiera till .env:  copy .env.example .env  (Windows)  eller  cp .env.example .env  (Mac/Linux)
# Fyll i dina värden nedan.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=reflektionsarkiv
# Lokal utveckling: ofta root. Produktion: reflektionsarkiv_app (se database/scripts/grants.sql).
# Schema/migrationer: kör som root eller reflektionsarkiv_admin — inte app-kontot (docs/DATABASE_SAKERHET.md).
DB_USER=root
DB_PASSWORD=

# Valfritt: AI-tolkning (server-side, nyckel exponeras aldrig i frontend)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# JWT för inloggning (byt till en lång slumpmässig hemlighet i produktion)
JWT_SECRET=dev-tyda-bytes-i-produktion-minst-32-tecken
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
